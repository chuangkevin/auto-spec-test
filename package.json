{
  "name": "auto-spec-test",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "concurrently --restart-tries 10 --restart-after 2000 -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "build": "pnpm --filter server build && pnpm --filter web build",
    "build:server": "pnpm --filter server build",
    "start:server": "pnpm --filter server start",
    "test": "pnpm --filter server test",
    "test:e2e": "pnpm --filter server test:e2e",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
